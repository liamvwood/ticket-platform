{
  "name": "image-transformer",
  "version": "1.0.0",
  "description": "Lambda@Edge function that resizes images on-demand using sharp",
  "main": "handler.js",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "sharp": "^0.33.0",
    "@aws-sdk/client-s3": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "jest": "^29.0.0"
  },
  "scripts": {
    "install:lambda": "npm ci --omit=dev --platform=linux --arch=x64",
    "test:unit": "jest test/handler.unit --testTimeout=30000",
    "test:integration": "jest test/integration --testTimeout=60000 --forceExit"
  },
  "jest": {
    "testEnvironment": "node"
  }
}
