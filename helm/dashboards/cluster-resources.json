{
  "title": "TicketPlatform – Cluster Resources",
  "uid": "tp-cluster-resources",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["ticketplatform", "cluster"],
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Cluster CPU Utilisation",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(node_cpu_seconds_total{mode!=\"idle\"}[2m])) / sum(rate(node_cpu_seconds_total[2m])) * 100",
          "legendFormat": "CPU %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 70 }, { "color": "red", "value": 90 }] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 2,
      "type": "gauge",
      "title": "Cluster Memory Utilisation",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "expr": "(1 - sum(node_memory_MemAvailable_bytes) / sum(node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "Memory %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 75 }, { "color": "red", "value": 90 }] }, "color": { "mode": "thresholds" } } }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Memory",
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(node_memory_MemTotal_bytes)", "legendFormat": "Total" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Memory Available",
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "sum(node_memory_MemAvailable_bytes)", "legendFormat": "Available" }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total CPU Cores",
      "gridPos": { "h": 3, "w": 6, "x": 12, "y": 3 },
      "targets": [
        { "expr": "count(node_cpu_seconds_total{mode=\"idle\"}) by (cpu) * 0 + count(count(node_cpu_seconds_total{mode=\"idle\"}) by (cpu, instance))", "legendFormat": "Cores" }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Ready Nodes",
      "gridPos": { "h": 3, "w": 6, "x": 18, "y": 3 },
      "targets": [
        { "expr": "sum(kube_node_status_condition{condition=\"Ready\",status=\"true\"})", "legendFormat": "Nodes" }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "CPU Usage per Node",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "targets": [
        {
          "expr": "sum(rate(node_cpu_seconds_total{mode!=\"idle\"}[2m])) by (instance) / sum(rate(node_cpu_seconds_total[2m])) by (instance) * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Memory Usage per Node",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "targets": [
        {
          "expr": "(node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes)",
          "legendFormat": "{{instance}} used"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Pod CPU Usage (ticket-platform namespace)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "targets": [
        {
          "expr": "sum(rate(container_cpu_usage_seconds_total{namespace=\"ticket-platform\",container!=\"\",container!=\"POD\"}[2m])) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Pod Memory Usage (ticket-platform namespace)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "targets": [
        {
          "expr": "sum(container_memory_working_set_bytes{namespace=\"ticket-platform\",container!=\"\",container!=\"POD\"}) by (pod)",
          "legendFormat": "{{pod}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    }
  ]
}
