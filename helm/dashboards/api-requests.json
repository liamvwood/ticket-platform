{
  "title": "TicketPlatform – API Requests",
  "uid": "tp-api-requests",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["ticketplatform"],
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_received_total{job=\"ticket-platform-api\"}[2m])) by (route, method)",
          "legendFormat": "{{method}} {{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Error Rate (5xx/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_requests_received_total{job=\"ticket-platform-api\",code=~\"5..\"}[2m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "fixedColor": "red", "mode": "fixed" } } }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Request Latency (p50 / p95 / p99)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=\"ticket-platform-api\"}[2m])) by (le, route))",
          "legendFormat": "p50 {{route}}"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=\"ticket-platform-api\"}[2m])) by (le, route))",
          "legendFormat": "p95 {{route}}"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=\"ticket-platform-api\"}[2m])) by (le, route))",
          "legendFormat": "p99 {{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Requests In-Progress",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "sum(http_requests_in_progress{job=\"ticket-platform-api\"})",
          "legendFormat": "In-Progress"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Requests (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_received_total{job=\"ticket-platform-api\"}[5m]))",
          "legendFormat": "Requests"
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "5xx Errors (last 5m)",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum(increase(http_requests_received_total{job=\"ticket-platform-api\",code=~\"5..\"}[5m]))",
          "legendFormat": "Errors"
        }
      ],
      "fieldConfig": { "defaults": { "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }, "color": { "mode": "thresholds" } } }
    }
  ]
}
